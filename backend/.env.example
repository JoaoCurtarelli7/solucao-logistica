# Banco de dados PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME"

# JWT — gere com: openssl rand -base64 48
# OBRIGATÓRIO em produção, mínimo 32 caracteres
JWT_SECRET="troque_por_um_segredo_forte_com_no_minimo_32_chars"

# OpenAI (para extração de documentos de carga)
OPENAI_API_KEY="sk-proj-..."

# Email do superadmin (garantido como ativo no startup)
OWNER_EMAIL="seu@email.com"

# Porta do servidor (padrão: 3333)
PORT=3333

# Ambiente: development | production
NODE_ENV=development

# Origens permitidas no CORS (separadas por vírgula)
# Em produção: defina o domínio real, ex: https://app.seudominio.com.br
# NÃO use * em produção
CORS_ORIGIN="http://localhost:3000,http://localhost:5173"

# URL pública do frontend (usada nos links dos emails)
APP_URL="http://localhost:3000"

# SMTP para envio de emails (boas-vindas, trial expirando, etc.)
# Gmail: host=smtp.gmail.com, port=587, secure=false
# Resend: host=smtp.resend.com, port=465, secure=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_de_app
SMTP_FROM="Derlei Sistema <noreply@seudominio.com.br>"

# Trial em dias para novos tenants aprovados (padrão: 14)
TRIAL_DAYS=14
