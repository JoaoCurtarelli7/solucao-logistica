{
  "name": "prisma-test",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "start:dev": "node --loader tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "postinstall": "node -e \"try { require.resolve('typescript'); } catch(e) { process.exit(0); } require('child_process').execSync('npm run build', {stdio:'inherit'});\"",
    "prisma:md": "prisma migrate dev --name init --create-only",
    "prisma:mm": "prisma migrate dev",
    "prisma:mr": "prisma migrate reset",
    "prisma:v": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force && node seed.js",
    "db:seed": "node seed.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": "18.x"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "prisma": "^5.22.0",
    "tsx": "^3.14.0",
    "typescript": "^5.2.2",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@fastify/multipart": "^7.7.3",
    "@fastify/rate-limit": "^8.1.1",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^1.10.2",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.53.1",
    "@types/jsonwebtoken": "^9.0.8",
    "bcrypt": "^5.1.1",
    "fastify": "^4.26.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.7",
    "openai": "^6.33.0",
    "pdf-parse": "^1.1.4",
    "zod": "^3.25.0"
  }
}
