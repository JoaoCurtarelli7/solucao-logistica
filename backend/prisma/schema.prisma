generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 Int                  @id @default(autoincrement())
  name               String
  cnpj               String?              @unique
  status             String               @default("active")
  plan               String               @default("trial")
  planExpiresAt      DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @default(now())
  User               User[]
  Employee           Employee[]
  Truck              Truck[]
  Trip               Trip[]
  Month              Month[]
  Company            Company[]
  FinancialEntry     FinancialEntry[]
  FinancialPeriod    FinancialPeriod[]
  Load               Load[]
  Closing            Closing[]
  LoadBillingClosing LoadBillingClosing[]
  Subscription       Subscription?
}

model Subscription {
  id               Int      @id @default(autoincrement())
  tenantId         Int      @unique
  plan             String   @default("trial")
  status           String   @default("active")
  startedAt        DateTime @default(now())
  expiresAt        DateTime?
  stripeSubId      String?
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Closing {
  id             Int              @id @default(autoincrement())
  monthId        Int
  companyId      Int?
  tenantId       Int
  name           String
  startDate      DateTime?
  endDate        DateTime?
  status         String           @default("aberto")
  totalEntries   Float            @default(0)
  totalExpenses  Float            @default(0)
  totalTaxes     Float            @default(0)
  balance        Float            @default(0)
  profitMargin   Float            @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @default(now())
  excludedSalaryEmployeeIds Int[] @default([])
  Tenant         Tenant           @relation(fields: [tenantId], references: [id])
  Company        Company?         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  Month          Month            @relation(fields: [monthId], references: [id], onDelete: Cascade)
  FinancialEntry FinancialEntry[]

  @@index([tenantId], map: "idx_closing_tenantId")
  @@index([companyId], map: "idx_closing_companyId")
  @@index([monthId], map: "idx_closing_monthId")
}

model Company {
  id                 Int                  @id @default(autoincrement())
  name               String
  type               String
  cnpj               String
  dateRegistration   DateTime
  status             String
  responsible        String
  commission         Float
  tenantId           Int
  Tenant             Tenant               @relation(fields: [tenantId], references: [id])
  Closing            Closing[]
  LoadBillingClosing LoadBillingClosing[]
  FinancialEntry     FinancialEntry[]
  FinancialPeriod    FinancialPeriod[]
  Load               Load[]

  @@unique([cnpj, tenantId])
  @@index([tenantId], map: "idx_company_tenantId")
}

model Employee {
  id          Int           @id @default(autoincrement())
  name        String
  role        String
  baseSalary  Float
  status      String
  pixAccount  String?
  cpf         String?
  phone       String?
  email       String?
  address     String?
  hireDate    DateTime      @default(now())
  tenantId    Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now())
  Tenant      Tenant        @relation(fields: [tenantId], references: [id])
  Transaction Transaction[]

  @@index([tenantId], map: "idx_employee_tenantId")
}

model FinancialEntry {
  id           Int      @id @default(autoincrement())
  description  String
  amount       Float
  category     String
  date         DateTime
  type         String
  observations String?
  closingId    Int?
  companyId    Int?
  tenantId     Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())
  Tenant       Tenant   @relation(fields: [tenantId], references: [id])
  Closing      Closing? @relation(fields: [closingId], references: [id], onDelete: Cascade)
  Company      Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([tenantId], map: "idx_finEntry_tenantId")
  @@index([closingId], map: "idx_finEntry_closingId")
  @@index([companyId], map: "idx_finEntry_companyId")
}

model FinancialPeriod {
  id            Int      @id @default(autoincrement())
  name          String
  startDate     DateTime
  endDate       DateTime
  companyId     Int?
  tenantId      Int
  status        String   @default("aberto")
  totalEntries  Float    @default(0)
  totalExpenses Float    @default(0)
  totalTaxes    Float    @default(0)
  balance       Float    @default(0)
  profitMargin  Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())
  Tenant        Tenant   @relation(fields: [tenantId], references: [id])
  Company       Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([tenantId], map: "idx_finPeriod_tenantId")
  @@index([companyId], map: "idx_finPeriod_companyId")
}

model Load {
  id                  Int      @id @default(autoincrement())
  date                DateTime
  loadingNumber       String
  deliveries          Int
  cargoWeight         Float
  totalValue          Float
  freight4            Float
  totalFreight        Float
  additionalCosts     Float    @default(0)
  additionalCostsNote String?
  observations        String?
  companyId           Int
  tenantId            Int
  Tenant              Tenant   @relation(fields: [tenantId], references: [id])
  Company             Company  @relation(fields: [companyId], references: [id])

  @@index([tenantId], map: "idx_load_tenantId")
  @@index([companyId], map: "idx_load_companyId")
}

model Maintenance {
  id        Int      @id @default(autoincrement())
  date      DateTime
  service   String
  km        Int
  value     Float
  notes     String?
  truckId   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  Truck     Truck    @relation(fields: [truckId], references: [id], onDelete: Cascade)

  @@index([truckId], map: "idx_maintenance_truckId")
}

model MaintenanceServicePreset {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Month {
  id                 Int                  @id @default(autoincrement())
  year               Int
  month              Int
  name               String
  tenantId           Int
  status             String               @default("aberto")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @default(now())
  Tenant             Tenant               @relation(fields: [tenantId], references: [id])
  Closing            Closing[]
  LoadBillingClosing LoadBillingClosing[]

  @@unique([year, month, tenantId], map: "uq_month_year_month_tenant")
  @@index([tenantId], map: "idx_month_tenantId")
}

model LoadBillingClosing {
  id                   Int      @id @default(autoincrement())
  monthId              Int
  companyId            Int
  tenantId             Int
  name                 String
  startDate            DateTime
  endDate              DateTime
  status               String   @default("aberto")
  totalLoads           Int      @default(0)
  totalGrossValue      Float    @default(0)
  totalFreight         Float    @default(0)
  commissionRate       Float    @default(0)
  totalCommission      Float    @default(0)
  totalAdditionalCosts Float    @default(0)
  billingTotal         Float    @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now())
  Tenant               Tenant   @relation(fields: [tenantId], references: [id])
  Month                Month    @relation(fields: [monthId], references: [id], onDelete: Cascade)
  Company              Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([tenantId], map: "idx_loadBillingClosing_tenantId")
  @@index([monthId], map: "idx_loadBillingClosing_monthId")
  @@index([companyId], map: "idx_loadBillingClosing_companyId")
}

model Transaction {
  id          Int      @id @default(autoincrement())
  type        String
  amount      Float
  date        DateTime @default(now())
  description String?
  employeeId  Int
  Employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId], map: "idx_transaction_employeeId")
}

model Trip {
  id               Int           @id @default(autoincrement())
  origin           String?
  destination      String
  driver           String
  date             DateTime
  estimatedArrival DateTime?
  freightValue     Float
  status           String        @default("em_andamento")
  notes            String?
  truckId          Int?
  tenantId         Int
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @default(now())
  Tenant           Tenant        @relation(fields: [tenantId], references: [id])
  Truck            Truck?        @relation(fields: [truckId], references: [id], onDelete: Restrict)
  TripExpense      TripExpense[]

  @@index([tenantId], map: "idx_trip_tenantId")
  @@index([truckId], map: "idx_trip_truckId")
}

model TripExpense {
  id          Int      @id @default(autoincrement())
  description String
  amount      Float
  date        DateTime
  category    String
  notes       String?
  tripId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  Trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId], map: "idx_tripExpense_tripId")
}

model Truck {
  id                          Int           @id @default(autoincrement())
  name                        String
  plate                       String
  brand                       String
  year                        Int
  docExpiry                   DateTime
  insuranceExpiry             DateTime?
  tachographCalibrationExpiry DateTime?
  oilChangeEngineDate         DateTime?
  oilChangeGearboxDate        DateTime?
  oilChangeDifferentialDate   DateTime?
  renavam                     String
  image                       String?
  tenantId                    Int
  Tenant                      Tenant        @relation(fields: [tenantId], references: [id])
  Maintenance                 Maintenance[]
  Trip                        Trip[]

  @@unique([plate, tenantId])
  @@index([tenantId], map: "idx_truck_tenantId")
}

model User {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  password     String
  phone        String?
  address      String?
  status       String     @default("active")
  roleId       Int?
  tenantId     Int
  isSuperAdmin Boolean    @default(false)
  createdAt    DateTime   @default(now())
  Tenant       Tenant     @relation(fields: [tenantId], references: [id])
  role         Role?      @relation(fields: [roleId], references: [id])
  AuditLog     AuditLog[]

  @@index([tenantId], map: "idx_user_tenantId")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now())
}

model Permission {
  id          Int              @id @default(autoincrement())
  key         String           @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now())
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String?
  createdAt DateTime @default(now())
}
