generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Closing {
  id             Int              @id @default(autoincrement())
  monthId        Int
  companyId      Int?
  name           String
  startDate      DateTime?
  endDate        DateTime?
  status         String           @default("aberto")
  totalEntries   Float            @default(0)
  totalExpenses  Float            @default(0)
  totalTaxes     Float            @default(0)
  balance        Float            @default(0)
  profitMargin   Float            @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @default(now())
  /// IDs de funcionários cujo salário calculado foi excluído deste fechamento
  excludedSalaryEmployeeIds Int[] @default([])
  Company        Company?         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  Month          Month            @relation(fields: [monthId], references: [id], onDelete: Cascade)
  FinancialEntry FinancialEntry[]

  @@index([companyId], map: "idx_closing_companyId")
  @@index([monthId], map: "idx_closing_monthId")
}

model Company {
  id                 Int                  @id @default(autoincrement())
  name               String
  type               String
  cnpj               String               @unique
  dateRegistration   DateTime
  status             String
  responsible        String
  commission         Float
  Closing            Closing[]
  LoadBillingClosing LoadBillingClosing[]
  FinancialEntry     FinancialEntry[]
  FinancialPeriod    FinancialPeriod[]
  Load               Load[]
}

model Employee {
  id          Int           @id @default(autoincrement())
  name        String
  role        String
  baseSalary  Float
  status      String
  // Conta Pix para depósito (opcional para manter compatibilidade com dados antigos)
  pixAccount  String?
  cpf         String?
  phone       String?
  email       String?
  address     String?
  hireDate    DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now())
  Transaction Transaction[]
}

model FinancialEntry {
  id           Int      @id @default(autoincrement())
  description  String
  amount       Float
  category     String
  date         DateTime
  type         String
  observations String?
  closingId    Int?
  companyId    Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())
  Closing      Closing? @relation(fields: [closingId], references: [id], onDelete: Cascade)
  Company      Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([closingId], map: "idx_finEntry_closingId")
  @@index([companyId], map: "idx_finEntry_companyId")
}

model FinancialPeriod {
  id            Int      @id @default(autoincrement())
  name          String
  startDate     DateTime
  endDate       DateTime
  companyId     Int?
  status        String   @default("aberto")
  totalEntries  Float    @default(0)
  totalExpenses Float    @default(0)
  totalTaxes    Float    @default(0)
  balance       Float    @default(0)
  profitMargin  Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())
  Company       Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId], map: "idx_finPeriod_companyId")
}

model Load {
  id                  Int      @id @default(autoincrement())
  date                DateTime
  loadingNumber       String
  deliveries          Int
  cargoWeight         Float
  totalValue          Float
  freight4            Float
  totalFreight        Float
  /// Custos extras cobrados junto com a comissão (descarga, pedágio, etc.)
  additionalCosts     Float    @default(0)
  additionalCostsNote String?
  observations        String?
  companyId           Int
  Company             Company  @relation(fields: [companyId], references: [id])

  @@index([companyId], map: "idx_load_companyId")
}

model Maintenance {
  id        Int      @id @default(autoincrement())
  date      DateTime
  service   String
  km        Int
  value     Float
  notes     String?
  truckId   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  Truck     Truck    @relation(fields: [truckId], references: [id], onDelete: Cascade)

  @@index([truckId], map: "idx_maintenance_truckId")
}

// Catálogo de serviços de manutenção (padrões + cadastrados pelo usuário)
model MaintenanceServicePreset {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Month {
  id                 Int                  @id @default(autoincrement())
  year               Int
  month              Int
  name               String
  status             String               @default("aberto")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @default(now())
  Closing            Closing[]
  LoadBillingClosing LoadBillingClosing[]

  @@unique([year, month], map: "uq_month_year_month")
}

model LoadBillingClosing {
  id                   Int      @id @default(autoincrement())
  monthId              Int
  companyId            Int
  name                 String
  startDate            DateTime
  endDate              DateTime
  status               String   @default("aberto")
  totalLoads           Int      @default(0)
  totalGrossValue      Float    @default(0)
  totalFreight         Float    @default(0)
  commissionRate       Float    @default(0)
  /// Comissão calculada só sobre o valor bruto (percentual da empresa)
  totalCommission      Float    @default(0)
  /// Soma dos custos adicionais das cargas no período
  totalAdditionalCosts Float    @default(0)
  billingTotal         Float    @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now())
  Month                Month    @relation(fields: [monthId], references: [id], onDelete: Cascade)
  Company              Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([monthId], map: "idx_loadBillingClosing_monthId")
  @@index([companyId], map: "idx_loadBillingClosing_companyId")
}

model Transaction {
  id          Int      @id @default(autoincrement())
  type        String
  amount      Float
  date        DateTime @default(now())
  // O que é a transação (opcional no schema para não quebrar registros antigos)
  description String?
  employeeId  Int
  Employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId], map: "idx_transaction_employeeId")
}

model Trip {
  id               Int           @id @default(autoincrement())
  origin           String? // Origem da viagem (rota: origem → destino)
  destination      String
  driver           String
  date             DateTime
  estimatedArrival DateTime? // Previsão de chegada
  freightValue     Float
  status           String        @default("em_andamento")
  notes            String?
  truckId          Int?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @default(now())
  Truck            Truck?        @relation(fields: [truckId], references: [id], onDelete: Restrict)
  TripExpense      TripExpense[]

  @@index([truckId], map: "idx_trip_truckId")
}

model TripExpense {
  id          Int      @id @default(autoincrement())
  description String
  amount      Float
  date        DateTime
  category    String
  notes       String?
  tripId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  Trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId], map: "idx_tripExpense_tripId")
}

model Truck {
  id                          Int           @id @default(autoincrement())
  name                        String
  plate                       String        @unique
  brand                       String
  year                        Int
  docExpiry                   DateTime
  insuranceExpiry             DateTime?
  tachographCalibrationExpiry DateTime?
  oilChangeEngineDate         DateTime?
  oilChangeGearboxDate        DateTime?
  oilChangeDifferentialDate   DateTime?
  renavam                     String
  image                       String?
  Maintenance                 Maintenance[]
  Trip                        Trip[]
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  password  String
  phone     String?
  address   String?
  status    String     @default("active")
  roleId    Int?
  role      Role?      @relation(fields: [roleId], references: [id])
  createdAt DateTime   @default(now())
  AuditLog  AuditLog[]
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now())
}

model Permission {
  id          Int              @id @default(autoincrement())
  key         String           @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now())
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String?
  createdAt DateTime @default(now())
}
